MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/God
JWT_SECRET=minimum-32-character-secret-key
JWT_EXPIRE=30d
PORT=10000
NODE_ENV=production
CORS_ORIGINS=https://your-web-app.onrender.com,https://your-admin-app.onrender.com
PUBLIC_API_BASE_URL=https://your-backend.onrender.com
WEB_APP_URL=https://your-web-app.onrender.com
TRUST_PROXY=true
DISABLE_PAYMENTS=true
ENABLE_SIMULATOR_API=false
ENABLE_OBSERVABILITY_INGEST=true
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-backend.onrender.com/api/auth/oauth/google/callback
GOOGLE_ANDROID_WEB_CLIENT_ID=
SENDGRID_API_KEY=
FROM_EMAIL=noreply@divya.app
FROM_NAME=Divya - Sacred Prayer App
ADMIN_BOOKING_ALERT_EMAILS=
CONTACT_ALERT_EMAILS=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MIXPANEL_TOKEN=
